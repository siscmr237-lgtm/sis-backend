// Prisma schema for SIS using PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id             String   @id @default(cuid())
  code           String   @unique @db.VarChar(16) // e.g., STU001
  firstName      String
  lastName       String
  dateOfBirth    DateTime
  gender         String
  class          String
  parentName     String
  parentPhone    String
  address        String
  enrollmentDate DateTime
  fees           Fee[]
}

model Staff {
  id       String  @id @default(cuid())
  code     String  @unique @db.VarChar(16) // e.g., STF001
  firstName String
  lastName  String
  role      String
  phone     String
  email     String @unique
  hireDate  DateTime
  salary    Int
  workRecords WorkRecord[]
}

model Fee {
  id            String  @id @default(cuid())
  code          String  @unique @db.VarChar(16) // e.g., FEE001
  student       Student @relation(fields: [studentId], references: [id])
  studentId     String
  studentName   String
  class         String
  term          String
  academicYear  String
  tuitionFee    Int
  registrationFee Int
  uniformFee    Int
  booksFee      Int
  otherFees     Int
  totalAmount   Int
  amountPaid    Int
  balance       Int
  paymentDate   DateTime
  paymentMethod String
}

model Expense {
  id           String @id @default(cuid())
  code         String @unique @db.VarChar(16) // e.g., EXP001
  date         DateTime
  category     String
  description  String
  amount       Int
  payee        String
  paymentMethod String
  invoiceNumber String @unique
}

model AttendanceRecord {
  id        String @id @default(cuid())
  code      String @unique @db.VarChar(16) // e.g., ATT001
  date      DateTime
  type      String
  personId  String
  personName String
  status    String
  remarks   String?
}

model WorkRecord {
  id        String @id @default(cuid())
  code      String @unique @db.VarChar(16) // e.g., WR001
  staff     Staff  @relation(fields: [staffId], references: [id])
  staffId   String
  staffName String
  date      DateTime
  subject   String
  class     String
  topic     String
  objectives String
  activities String
  evaluation String
  remarks    String?
}

model ReportCard {
  id           String @id @default(cuid())
  code         String @unique @db.VarChar(16) // e.g., RC001
  studentId    String
  studentName  String
  class        String
  term         String
  academicYear String
  subjects     Json
  averageScore Int
  position     Int
  totalStudents Int
  attendance   Int
  headTeacherComment String
}

model TimetableEntry {
  id      String @id @default(cuid())
  code    String @unique @db.VarChar(16) // e.g., TT001
  day     String
  time    String
  class   String
  subject String
  teacher String
}

model SchoolSettings {
  id             Int    @id @default(1)
  name           String
  logo           String
  academicYear   String
  currentTerm    String
  subjectsPerClass Json
}

model FeeCategory {
  id        Int     @id @default(autoincrement())
  name      String  @unique
  limit     Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  phoneNumber  String   @unique
  passwordHash String
  name         String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
