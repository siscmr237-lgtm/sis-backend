// Prisma schema for SIS using PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id             Int      @id @default(autoincrement())
  code           String   @unique @db.VarChar(16) // e.g., STU001
  school         School   @relation(fields: [schoolId], references: [id])
  schoolId       Int
  firstName      String
  lastName       String
  dateOfBirth    DateTime
  gender         String
  class          String
  parentName     String
  parentPhone    String
  address        String
  enrollmentDate     DateTime
  allergies          String?
  medicalConditions  String?
  currentMedications String?
  medicalNotes       String?
  ledgerEntries      LedgerEntry[]
  pickupContacts     PickupContact[]

  @@index([schoolId])
  @@index([schoolId, class])
}

model PickupContact {
  id           Int      @id @default(autoincrement())
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId    Int
  name         String
  phone        String
  relationship String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([studentId])
}

model Staff {
  id                    Int                    @id @default(autoincrement())
  code                  String                 @unique @db.VarChar(16) // e.g., STF001
  school                School                 @relation(fields: [schoolId], references: [id])
  schoolId              Int
  firstName             String
  lastName              String
  role                  String
  phone                 String
  email                 String                 @unique
  hireDate              DateTime
  salary                Int
  isTeacher             Boolean                @default(false)
  workRecords           WorkRecord[]
  classesAsClassTeacher Class[]                @relation("ClassTeacher")
  subjectAssignments    ClassSubjectTeacher[]
  ledgerEntries         LedgerEntry[]

  @@index([schoolId])
}

model Expense {
  id            Int      @id @default(autoincrement())
  code          String   @unique @db.VarChar(16) // e.g., EXP001
  school        School   @relation(fields: [schoolId], references: [id])
  schoolId      Int
  date          DateTime
  category      String
  description   String
  amount        Int
  payee         String
  paymentMethod String
  invoiceNumber String   @unique

  @@index([schoolId, date])
}

model AttendanceRecord {
  id         Int      @id @default(autoincrement())
  code       String   @unique @db.VarChar(16) // e.g., ATT001
  school     School   @relation(fields: [schoolId], references: [id])
  schoolId   Int
  date       DateTime
  type       String
  personId   String
  personName String
  status     String
  remarks    String?

  @@index([schoolId, date])
  @@index([schoolId, personId])
}

model WorkRecord {
  id         Int      @id @default(autoincrement())
  code       String   @unique @db.VarChar(16) // e.g., WR001
  staff      Staff    @relation(fields: [staffId], references: [id])
  school     School   @relation(fields: [schoolId], references: [id])
  schoolId   Int
  staffId    Int
  staffName  String
  date       DateTime
  subject    String
  class      String
  topic      String
  objectives String
  activities String
  evaluation String
  remarks    String?

  @@index([schoolId])
  @@index([staffId, schoolId])
}

model ReportCard {
  id                 Int    @id @default(autoincrement())
  code               String @unique @db.VarChar(16) // e.g., RC001
  school             School @relation(fields: [schoolId], references: [id])
  schoolId           Int
  studentId          String
  studentName        String
  class              String
  term               String
  academicYear       String
  subjects           Json
  averageScore       Int
  position           Int
  totalStudents      Int
  attendance         Int
  headTeacherComment String

  @@index([schoolId])
  @@index([schoolId, studentId])
  @@index([schoolId, term, academicYear])
}

model TimetableEntry {
  id       Int    @id @default(autoincrement())
  code     String @unique @db.VarChar(16) // e.g., TT001
  school   School @relation(fields: [schoolId], references: [id])
  schoolId Int
  day      String
  time     String
  class    String
  subject  String
  teacher  String

  @@index([schoolId])
  @@index([schoolId, class])
}

model Class {
  id              Int                    @id @default(autoincrement())
  code            String                 @unique @db.VarChar(16)
  name            String
  school          School                 @relation(fields: [schoolId], references: [id])
  schoolId        Int
  classTeacher    Staff?                 @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  classTeacherId  Int?
  subjectTeachers ClassSubjectTeacher[]
  classSubjects   ClassSubject[]

  @@unique([name, schoolId])
}

model Subject {
  id              Int                   @id @default(autoincrement())
  name            String
  school          School                @relation(fields: [schoolId], references: [id])
  schoolId        Int
  classSubjects   ClassSubject[]
  subjectTeachers ClassSubjectTeacher[]

  @@unique([name, schoolId])
}

model ClassSubject {
  id        Int     @id @default(autoincrement())
  class     Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId   Int
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId Int

  @@unique([classId, subjectId])
}

model ClassSubjectTeacher {
  id        Int     @id @default(autoincrement())
  class     Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId   Int
  staff     Staff   @relation(fields: [staffId], references: [id])
  staffId   Int
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId Int

  @@unique([classId, staffId, subjectId])
}

enum SchoolType {
  DAYCARE_NURSERY
  DAYCARE_NURSERY_PRIMARY
}

model School {
  id                   Int                @id @default(autoincrement())
  name                 String
  logo                 String
  academicYear         String
  currentTerm          String
  motto                String?
  address              String?
  schoolType           SchoolType?
  uniformColors        Json               @default("[]")
  onboardingCompleted  Boolean            @default(true)
  subjectsPerClass     Json
  adminUser            AdminUser          @relation(fields: [adminUserId], references: [id])
  adminUserId          Int
  Student              Student[]
  Staff                Staff[]
  Expense              Expense[]
  AttendanceRecord     AttendanceRecord[]
  WorkRecord           WorkRecord[]
  ReportCard           ReportCard[]
  TimetableEntry       TimetableEntry[]
  Class                Class[]
  Subject              Subject[]
  chargeCategories     ChargeCategory[]
  ledgerEntries        LedgerEntry[]
}

model ChargeCategory {
  id        Int           @id @default(autoincrement())
  name      String
  limit     Int           @default(0)
  isBuiltIn Boolean       @default(false)
  forStaff  Boolean       @default(false)
  school    School        @relation(fields: [schoolId], references: [id])
  schoolId  Int
  entries   LedgerEntry[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([name, schoolId])
}

enum LedgerEntryType {
  CHARGE
  PAYMENT
}

model LedgerEntry {
  id            Int             @id @default(autoincrement())
  code          String          @unique @db.VarChar(16)
  type          LedgerEntryType
  school        School          @relation(fields: [schoolId], references: [id])
  schoolId      Int
  student       Student?        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId     Int?
  staff         Staff?          @relation(fields: [staffId], references: [id], onDelete: Cascade)
  staffId       Int?
  category      ChargeCategory? @relation(fields: [categoryId], references: [id])
  categoryId    Int?
  description   String
  amount        Int
  entryDate     DateTime
  paymentMethod String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([studentId, schoolId])
  @@index([staffId, schoolId])
  @@index([schoolId])
}

model AdminUser {
  id            Int      @id @default(autoincrement())
  phoneNumber   String   @unique
  email         String?  @unique
  passwordHash  String
  name          String
  role          String   @default("admin")
  isActive      Boolean  @default(true)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  School        School[]
}

enum OtpPurpose {
  SIGNUP_VERIFICATION
  PASSWORD_RESET
}

model OtpCode {
  id                Int        @id @default(autoincrement())
  purpose           OtpPurpose
  identifier        String
  codeHash          String
  expiresAt         DateTime
  attemptsRemaining Int        @default(5)
  consumed          Boolean    @default(false)
  createdAt         DateTime   @default(now())

  @@index([identifier, purpose])
}
